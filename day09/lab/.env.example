# Day 09 Lab — Environment Variables
# Copy file này thành .env và điền giá trị thật:
#   cp .env.example .env

# ─── Chọn 1 trong 2 LLM provider ───

# Option A: OpenAI (GPT-4o-mini hoặc GPT-4o)
OPENAI_API_KEY=

# Option B: Google Gemini
GOOGLE_API_KEY=
LLM_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-1.5-flash

# ─── Cấu hình ChromaDB ───
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=day09_docs

# ─── Cấu hình Retrieval ───
RETRIEVAL_TOP_K=5
EMBEDDING_MODEL=all-MiniLM-L6-v2
